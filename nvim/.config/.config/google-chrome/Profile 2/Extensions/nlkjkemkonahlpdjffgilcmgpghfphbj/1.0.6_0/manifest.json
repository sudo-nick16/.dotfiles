{
   "background": {
      "persistent": false,
      "scripts": [ "browser-polyfill.js", "background.js" ]
   },
   "browser_action": {
      "default_icon": "assets/icon16.png",
      "default_popup": "index.html",
      "default_title": "Twitter video downloader history"
   },
   "content_scripts": [ {
      "css": [ "styles/twitter.css" ],
      "js": [ "browser-polyfill.js", "contentScripts.js" ],
      "matches": [ "https://twitter.com/*" ]
   } ],
   "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
   "description": "Twitter Video Downloader allows you to download twitter videos but also copy easyly their shareable link.",
   "icons": {
      "128": "assets/icon128.png",
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png"
   },
   "key": "",
   "manifest_version": 2,
   "name": "Twitter Video Downloader",
   "permissions": [ "storage", "downloads" ],
   "short_name": "TVD",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.0.6"
}
