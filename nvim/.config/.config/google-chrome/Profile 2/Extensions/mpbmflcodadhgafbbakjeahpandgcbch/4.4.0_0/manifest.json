{
   "action": {
      "default_icon": {
         "16": "./assets/production/16.png",
         "24": "./assets/production/24.png",
         "32": "./assets/production/32.png"
      }
   },
   "background": {
      "service_worker": "background.js",
      "type": "module"
   },
   "default_locale": "en",
   "description": "__MSG_appDesc__",
   "homepage_url": "https://github.com/rossmoody/svg-gobbler",
   "host_permissions": [ "https://us-central1-svg-gobbler.cloudfunctions.net/SVGR" ],
   "icons": {
      "128": "./assets/production/128.png",
      "16": "./assets/production/16.png",
      "32": "./assets/production/32.png",
      "48": "./assets/production/48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_appName__",
   "permissions": [ "activeTab", "scripting" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "4.4.0",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "pages/index.html", "pages/welcome.html", "pages/favicon.ico", "assets/development/*.png" ]
   } ]
}
