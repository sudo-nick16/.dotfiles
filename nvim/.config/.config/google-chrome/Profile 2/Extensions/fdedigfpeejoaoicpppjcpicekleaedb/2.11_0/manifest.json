{
   "background": {
      "scripts": [ "js/background.js", "js/instaBg.js" ]
   },
   "browser_action": {
      "default_icon": "assets/64.png",
      "default_popup": "html/popup.html"
   },
   "content_scripts": [ {
      "css": [ "css/extension.css" ],
      "js": [ "js/extension.js", "js/transform.js", "js/content.js" ],
      "matches": [ "*://*.instagram.com/*" ]
   } ],
   "default_locale": "en",
   "description": "__MSG_appDesc__",
   "icons": {
      "128": "assets/128.png",
      "32": "assets/32.png",
      "64": "assets/64.png"
   },
   "key": "",
   "manifest_version": 2,
   "name": "__MSG_appName__",
   "permissions": [ "storage", "cookies", "webRequest", "webRequestBlocking", "downloads", "tabs", "\u003Call_urls>" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "2.11",
   "web_accessible_resources": [ "assets/*" ]
}
