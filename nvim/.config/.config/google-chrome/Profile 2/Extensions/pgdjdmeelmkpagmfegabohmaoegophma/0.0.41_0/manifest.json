{
   "background": {
      "persistent": true,
      "scripts": [ "background/background_script.js" ]
   },
   "browser_action": {
      "default_icon": "assets/icon.png",
      "default_popup": "popup/popup.html",
      "default_title": "The Beagle Button"
   },
   "content_scripts": [ {
      "js": [ "content/content_script.js" ],
      "matches": [ "https://*/*", "http://*/*" ],
      "run_at": "document_end"
   } ],
   "content_security_policy": "script-src 'self'; object-src 'self'",
   "cross_origin_embedder_policy": {
      "value": "require-corp"
   },
   "cross_origin_opener_policy": {
      "value": "same-origin"
   },
   "description": "The Beagle Button - the magic way to shop sustainably",
   "icons": {
      "128": "assets/icon.png"
   },
   "key": "",
   "manifest_version": 2,
   "name": "The Beagle Button - Sustainable Shopping",
   "permissions": [ "tabs", "storage" ],
   "short_name": "The Beagle Button",
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "0.0.41",
   "web_accessible_resources": [ "inline/inline.html", "assets/icon.svg", "assets/inline-result-icon.svg", "util/reporting.js" ]
}
