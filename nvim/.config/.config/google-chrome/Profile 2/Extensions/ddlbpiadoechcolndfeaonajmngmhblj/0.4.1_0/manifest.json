{
   "author": "compose.ai",
   "background": {
      "persistent": true,
      "scripts": [ "background.js" ]
   },
   "browser_action": {
      "default_icon": "assets/compose_logo_48.png",
      "default_popup": "popup.html",
      "default_title": "Compose AI"
   },
   "content_scripts": [ {
      "all_frames": false,
      "js": [ "general.js" ],
      "matches": [ "http://*/*", "https://*/*" ],
      "run_at": "document_idle"
   }, {
      "all_frames": false,
      "hostnames": [ "mail.google.com" ],
      "js": [ "gmail.js" ],
      "matches": [ "*://mail.google.com/*" ],
      "run_at": "document_idle"
   }, {
      "hostnames": [ "docs.google.com" ],
      "js": [ "gdocs.js" ],
      "matches": [ "*://docs.google.com/*" ],
      "run_at": "document_idle"
   }, {
      "all_frames": false,
      "hostnames": [ "mail.superhuman.com" ],
      "js": [ "superhuman.js" ],
      "matches": [ "*://mail.superhuman.com/*" ],
      "run_at": "document_idle"
   }, {
      "all_frames": false,
      "hostnames": [ "outlook.office.com", "outlook.office365.com", "outlook.live.com" ],
      "js": [ "outlook.js" ],
      "matches": [ "*://outlook.office.com/*", "*://outlook.office365.com/*", "*://outlook.live.com/*" ],
      "run_at": "document_idle"
   }, {
      "all_frames": false,
      "hostnames": [ "www.linkedin.com", "linkedin.com" ],
      "js": [ "linkedin.js" ],
      "matches": [ "*://www.linkedin.com/*", "*://linkedin.com/*" ],
      "run_at": "document_idle"
   }, {
      "all_frames": false,
      "hostnames": [ "guide.compose.ai" ],
      "js": [ "guide.js" ],
      "matches": [ "*://guide.compose.ai/*" ],
      "run_at": "document_idle"
   } ],
   "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
   "description": "AI that writes your emails.",
   "differential_fingerprint": "1.dc3e620b69eaa2fe93b93926e71224abc0eca537774fa9b5583c84a1d9c2069d",
   "externally_connectable": {
      "matches": [ "https://mail.google.com/*", "https://*.compose.ai/*", "https://compose-2.webflow.io/*" ]
   },
   "icons": {
      "128": "assets/compose_logo_128.png"
   },
   "key": "",
   "manifest_version": 2,
   "name": "Compose AI: AI-powered Writing Tool",
   "permissions": [ "tabs", "webNavigation", "https://*/", "management", "alarms", "clipboardWrite" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "0.4.1",
   "version_name": "0.4.1-rc1",
   "web_accessible_resources": [ "assets/compose_logo_128.png", "assets/loader.svg", "assets/michael.png", "assets/wilson.png", "assets/promo_code_accent_bottom_right.png", "assets/promo_code_accent_top_left.png", "assets/rephrase_logo.png", "assets/logo-with-text.png" ]
}
