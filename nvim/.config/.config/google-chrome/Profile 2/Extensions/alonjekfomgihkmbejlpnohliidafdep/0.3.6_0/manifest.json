{
   "background": {
      "persistent": true,
      "scripts": [ "browser-id3-writer.js", "crunker.js", "background.js" ]
   },
   "browser_action": {
      "default_icon": "assets/icon.png",
      "default_popup": "popup.html"
   },
   "content_scripts": [ {
      "css": [ "styles.css" ],
      "js": [ "content-script.js" ],
      "matches": [ "https://*.soundcloud.com/*" ]
   } ],
   "description": "This extension will let you download any track from Soundcloud.",
   "icons": {
      "128": "assets/icon-128.png",
      "16": "assets/icon.png",
      "48": "assets/icon-48.png"
   },
   "key": "",
   "manifest_version": 2,
   "name": "Soundcloud Download",
   "permissions": [ "https://*.soundcloud.com/*", "tabs", "webRequest", "downloads", "webNavigation", "storage" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "0.3.6",
   "web_accessible_resources": [ "assets/*" ]
}
